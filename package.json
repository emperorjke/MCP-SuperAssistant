{
  "name": "mcp-superassistant",
  "version": "0.2.0",
  "description": "Chrome extension that brings MCP to AI platforms including Scira.AI",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "zip": "node scripts/zip.js",
    "start:proxy": "npx @srbhptl39/mcp-superassistant-proxy@latest",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.256",
    "@types/jest": "^29.5.8",
    "@types/node": "^22.5.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "archiver": "^6.0.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-transform-stub": "^2.0.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/src/test-setup.ts"
    ],
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.test.{ts,tsx}",
      "<rootDir>/tests/**/*.test.{ts,tsx}",
      "<rootDir>/pages/**/*.test.{ts,tsx}"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@src/(.*)$": "<rootDir>/pages/content/src/$1",
      "\\.(css|less|sass|scss)$": "<rootDir>/src/__mocks__/styleMock.js",
      "^@src/.+\\.(css|less|sass|scss)$": "<rootDir>/src/__mocks__/styleMock.js"
    },
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest",
      "^.+\\.(css|less|sass|scss)$": "jest-transform-stub"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/test-setup.ts"
    ]
  },
  "keywords": [
    "chrome-extension",
    "mcp",
    "ai",
    "scira",
    "perplexity",
    "chatgpt",
    "tools"
  ],
  "author": "emperorjke",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/emperorjke/MCP-SuperAssistant.git"
  }
}